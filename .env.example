# Backend server
PORT=5001
APP_PUBLIC_URL=https://your-public-domain.com
API_PUBLIC_URL=https://your-api-domain.com
FRONTEND_URL=https://your-frontend-domain.com
# Use Lax when frontend/API are same-site. Use None only for cross-site HTTPS deployments.
# Use None when frontend and API are on different sites; requires NODE_ENV=production (Secure cookies).
AUTH_COOKIE_SAME_SITE=None

# Supabase
# Required for auth, workspace, onboarding, leads, calls, outcomes, and meetings.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Required for provider webhooks and background workers because those requests
# do not have a signed-in user session.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Apollo lead import
# Required for Apollo search + enrichment.
APOLLO_API_KEY=your-apollo-api-key

# Required for Apollo phone/email enrichment callbacks.
# If omitted, the backend derives it from APP_PUBLIC_URL.
APOLLO_WEBHOOK_URL=https://your-public-domain.com/api/apollo/webhook

# Retell voice agent + calls
# Required to create Retell LLMs/agents and place outbound calls.
RETELL_API_KEY=your-retell-api-key
RETELL_API_BASE=https://api.retellai.com
RETELL_DEFAULT_VOICE_ID=11labs-Adrian

# AI provider. Azure OpenAI is selected automatically when its three required
# variables below are present. Uncomment only when you need to override that
# automatic selection.
# AI_PROVIDER=azure-openai
AI_MAX_RETRIES=3

# Gemini fallback (used only when Azure OpenAI is not configured or AI_PROVIDER=gemini).
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.5-flash

# Azure OpenAI. The deployment is your Azure deployment name, not merely a model family.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=your-chat-deployment-name
AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# Email V1
# Required for encrypting user SMTP/IMAP passwords in connected_accounts.
# Use a long random string or a 64-character hex key.
ENCRYPTION_KEY=replace-with-a-long-random-secret

# Required for BullMQ email send/reply polling workers.
REDIS_URL=redis://127.0.0.1:6379
EMAIL_SEND_WORKER_CONCURRENCY=3
LEAD_IMPORT_WORKER_CONCURRENCY=2
LEAD_IMPORT_WORKER_ENABLED=true
POLL_INBOX_INTERVAL_MS=180000

# Required when creating Retell agents so Retell can send call events back.
RETELL_WEBHOOK_URL=https://your-public-domain.com/api/retell/webhook

# Optional but recommended once Retell webhook signing is configured.
RETELL_WEBHOOK_SECRET=your-retell-webhook-secret

# Automatic calling queue
# Keep false until Supabase service role, Retell, telephony, and compliance
# checks have been verified with test leads.
CALLING_QUEUE_ENABLED=false
CALLING_QUEUE_INTERVAL_MS=60000

# PDPC DNC API
# Currently paused. Leave blank until the official DNC account/API approval,
# UAT, IP allowlist, and key setup are complete.
PDPC_DNC_API_URL=
PDPC_DNC_ACCOUNT_ID=
